# ── Secrets / credentials ──────────────────────────────
.env
.env.*
*.key
*.pem
*credentials*
*secret*

# ── Generated outputs (audio, video, manifests) ───────
# Outputs land in the project's CWD/output/, but if someone
# runs scripts from inside the skill dir, exclude them here too.
output/
output/**

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / editor configs ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs / temp / cache ────────────────────────────────
*.log
*.tmp
*.jsonl
*.zip
.cache/
.pytest_cache/
htmlcov/
.coverage

# ── OS junk ────────────────────────────────────────────
desktop.ini
ehthumbs.db
